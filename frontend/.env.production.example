# Option 1 (recommended for Netlify/Vercel/GitHub Pages + separate backend):
REACT_APP_API_BASE_URL=https://api.your-domain.com/api/auth/
REACT_APP_API_URL=https://api.your-domain.com/api/auth/

# Production build guard: at least one of REACT_APP_API_BASE_URL, REACT_APP_API_URL,
# REACT_APP_API_HOST, REACT_APP_USE_SAME_ORIGIN_API, or
# REACT_APP_ALLOW_PRODUCTION_API_FALLBACK must be set.

# Option 2: same-origin API (only when frontend is served by the same Django host/domain)
# REACT_APP_USE_SAME_ORIGIN_API=true

# Optional safety valve to allow same-origin fallback in production when explicit API vars are missing.
# Keep this disabled for Netlify + separate backend deployments.
# REACT_APP_ALLOW_PRODUCTION_API_FALLBACK=true

# If no frontend API env vars are set in a production build, the app now
# throws a configuration error to prevent silent misrouting.

# Option 3: host-level control (used when API_BASE_URL is not set)
# REACT_APP_API_PROTOCOL=https:
# REACT_APP_API_HOST=api.your-domain.com
# REACT_APP_API_PORT=

