# Local default: backend on localhost:8000
# REACT_APP_API_BASE_URL=http://localhost:8000/api/auth/
# REACT_APP_API_URL=http://localhost:8000/api/auth/

# Dev server binding (default script sets HOST=localhost)
# HOST=localhost
# PORT=3000
# To expose on local network, use: npm run start:lan

# Use same-origin only when frontend is served by the backend host.
# REACT_APP_USE_SAME_ORIGIN_API=true

# Required for split production deployments (Netlify/Vercel/GitHub Pages + API host):
# REACT_APP_API_BASE_URL=https://your-api-domain/api/auth/
# REACT_APP_API_URL=https://your-api-domain/api/auth/
# REACT_APP_API_PROTOCOL=https:
# REACT_APP_API_HOST=api.your-domain.com
# REACT_APP_API_PORT=

# Optional safety valve only if you intentionally want same-origin fallback in production.
# Not recommended for Netlify + separate backend deployments.
# REACT_APP_ALLOW_PRODUCTION_API_FALLBACK=true