# Django core
SECRET_KEY=replace-with-a-50-plus-character-random-secret
DEBUG=False
ALLOWED_HOSTS=your-backend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.netlify.app,https://your-custom-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.netlify.app,https://your-custom-domain.com

# Optional for dynamic Netlify preview/branch URLs (regex, comma-separated)
# Example allows: main site and deploy-preview / branch deploy URLs
# CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.netlify\.app$,^https://deploy-preview-\d+--[a-z0-9-]+\.netlify\.app$,^https://[a-z0-9-]+--[a-z0-9-]+\.netlify\.app$
# CSRF_TRUSTED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.netlify\.app$,^https://deploy-preview-\d+--[a-z0-9-]+\.netlify\.app$,^https://[a-z0-9-]+--[a-z0-9-]+\.netlify\.app$

# Database (recommended: managed PostgreSQL on Render)
# Preferred: use DATABASE_URL from Render database service connection string.
DATABASE_URL=postgresql://user:password@host:5432/database
DB_CONN_MAX_AGE=60
DB_SSLMODE=require

# Optional explicit config if DATABASE_URL is not used.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_render_postgres_database
# DB_USER=your_render_postgres_user
# DB_PASSWORD=your_render_postgres_password
# DB_HOST=your_render_postgres_host
# DB_PORT=5432

# SQLite is supported for local/dev only.
# If you still use SQLite in production, you must mount a persistent disk and point DB_NAME there.
# ALLOW_SQLITE_IN_PRODUCTION=True
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=/opt/render/project/src/backend/db.sqlite3

# Security hardening
SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_HOST=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=False
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
X_FRAME_OPTIONS=DENY
CORS_ALLOW_CREDENTIALS=False

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# SMS provider
SMS_PROVIDER_USER=YOUR_PROFILE_ID
SMS_PROVIDER_PASSWORD=YOUR_PASSWORD
SMS_DEFAULT_SENDER_IDS=SENDERID
