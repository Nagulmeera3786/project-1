# Core Django
SECRET_KEY=change-this-to-a-long-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# For split hosting (Netlify frontend + separate Django backend):
CORS_ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-site.netlify.app

# Database Configuration (SQLite default)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Optional MySQL override
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=abc_sms
# DB_USER=root
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_CONN_MAX_AGE=60
# DB_CHARSET=utf8mb4

# Gmail Configuration for OTP emails
# To use real email sending:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an app password at https://myaccount.google.com/apppasswords
# 3. Copy your 16-character app password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=your-email@gmail.com

# Real-time SMS Provider Configuration
# These map to your working script values:
# user   -> SMS_PROVIDER_USER
# pwd    -> SMS_PROVIDER_PASSWORD
# sender -> SMS_DEFAULT_SENDER_IDS (comma-separated if multiple)
SMS_PROVIDER_USER=YOUR_PROFILE_ID
SMS_PROVIDER_PASSWORD=YOUR_PASSWORD
SMS_PROVIDER_URL=https://mshastra.com/bsms/buser/send_sms_center.aspx
SMS_PROVIDER_JSON_URL=https://mshastra.com/sendsms_api_json.aspx
SMS_DEFAULT_SENDER_IDS=SENDERID
